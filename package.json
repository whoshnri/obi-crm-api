{
  "name": "obi-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "postinstall": "npm run prisma:generate",
    "prisma:generate": "prisma generate && node scripts/fix-esm-imports.mjs",
    "fix:esm-imports": "node scripts/fix-esm-imports.mjs",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "seed": "bun prisma/seed.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.5",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/extension-accelerate": "^3.0.1",
    "argon2": "^0.44.0",
    "bunqueue": "^2.7.14",
    "dotenv": "^17.4.2",
    "hono": "^4.10.7",
    "ioredis": "^5.9.3",
    "pg": "^8.20.0",
    "stripe": "^20.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "@types/node": "^20.19.25",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "typescript": "^5.9.3"
  }
}
