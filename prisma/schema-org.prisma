// ─── ADMIN ↔ PROGRAMME ASSIGNMENT ────────────

model AdminProgrammeAssignment {
  id            String     @id @default(cuid())
  adminId       String
  programmeId   String
  roleId        String?    // optional role override scoped to this programme
  assignedAt    DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  admin         Admin      @relation(fields: [adminId], references: [id], onDelete: Cascade)
  programme     Programme  @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  role          Role?      @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([adminId, programmeId])
  @@index([adminId])
  @@index([programmeId])
}


// ─── GENERAL (ORG-WIDE) COMMS ────────────────

model OrgCommsThread {
  id          String               @id @default(cuid())
  authorId    String
  title       String
  body        String
  isPinned    Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  author      Admin                @relation("OrgCommsAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  tags        OrgCommsTag[]
  replies     OrgCommsReply[]
}

model OrgCommsReply {
  id        String          @id @default(cuid())
  threadId  String
  authorId  String
  body      String
  parentId  String?         // null = direct reply to thread; set = reply to another reply
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  thread    OrgCommsThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author    Admin           @relation("OrgCommsReplyAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parent    OrgCommsReply?  @relation("OrgCommsReplies", fields: [parentId], references: [id], onDelete: SetNull)
  children  OrgCommsReply[] @relation("OrgCommsReplies")

  @@index([threadId])
  @@index([authorId])
  @@index([parentId])
}

// Tagged admins on an org comms thread
model OrgCommsTag {
  id        String         @id @default(cuid())
  threadId  String
  adminId   String
  thread    OrgCommsThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  admin     Admin          @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([threadId, adminId])
}


// ─── PROGRAMME-SCOPED COMMS ──────────────────

// One channel auto-created per programme
model ProgrammeCommsChannel {
  id          String                @id @default(cuid())
  programmeId String                @unique
  createdAt   DateTime              @default(now())
  programme   Programme             @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  threads     ProgrammeCommsThread[]
}

model ProgrammeCommsThread {
  id         String                  @id @default(cuid())
  channelId  String
  authorId   String
  title      String
  body       String
  isPinned   Boolean                 @default(false)
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  channel    ProgrammeCommsChannel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author     Admin                   @relation("ProgrammeCommsAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  tags       ProgrammeCommsTag[]
  replies    ProgrammeCommsReply[]

  @@index([channelId])
}

model ProgrammeCommsReply {
  id        String               @id @default(cuid())
  threadId  String
  authorId  String
  body      String
  parentId  String?              // null = direct reply; set = reply to a reply
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  thread    ProgrammeCommsThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author    Admin                @relation("ProgrammeCommsReplyAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parent    ProgrammeCommsReply? @relation("ProgrammeCommsReplies", fields: [parentId], references: [id], onDelete: SetNull)
  children  ProgrammeCommsReply[] @relation("ProgrammeCommsReplies")

  @@index([threadId])
  @@index([authorId])
  @@index([parentId])
}

model ProgrammeCommsTag {
  id        String               @id @default(cuid())
  threadId  String
  adminId   String
  thread    ProgrammeCommsThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  admin     Admin                @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([threadId, adminId])
}


// ─── NOTIFICATIONS ───────────────────────────

enum NotificationType {
  form_submission
  event_run
  event_failed
  payment_received
  payment_overdue
  invoice_sent
  participant_added
  participant_updated
  programme_update
  task_assigned
  task_completed
  comms_tag
  admin_added
  error
  info
}

model Notification {
  id          String           @id @default(cuid())
  adminId     String           // recipient
  type        NotificationType
  title       String
  body        String?
  read        Boolean          @default(false)
  payload     Json             @default("{}")  // contextual data (ids, links, etc.)
  createdAt   DateTime         @default(now())
  admin       Admin            @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([read])
  @@index([createdAt])
}


// ─── TASKS ───────────────────────────────────

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum TaskStatus {
  open
  in_progress
  blocked
  done
  cancelled
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  programmeId String?      // optional programme context
  assigneeId  String?      // admin assigned to the overall task
  createdById String
  priority    TaskPriority @default(medium)
  status      TaskStatus   @default(open)
  dueDate     DateTime?
  metadata    Json         @default("{}")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  assignee    Admin?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy   Admin        @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  programme   Programme?   @relation(fields: [programmeId], references: [id], onDelete: SetNull)
  items       TaskItem[]

  @@index([assigneeId])
  @@index([programmeId])
  @@index([status])
}

model TaskItem {
  id          String    @id @default(cuid())
  taskId      String
  label       String
  completed   Boolean   @default(false)
  assigneeId  String?   // optional per-item assignee
  order       Int       @default(0)  // for ordering items in UI
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignee    Admin?    @relation("TaskItemAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([assigneeId])
}


// ─── PROGRAMME RESOURCES ─────────────────────

enum ResourceType {
  link
  document
  video
  spreadsheet
  image
  other
}

model ProgrammeResource {
  id          String       @id @default(cuid())
  programmeId String
  label       String
  url         String
  type        ResourceType @default(link)
  description String?
  addedById   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  programme   Programme    @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  addedBy     Admin?       @relation(fields: [addedById], references: [id], onDelete: SetNull)

  @@index([programmeId])
}
