// ─────────────────────────────────────────────
// ORGANISATIONAL SCHEMA ADDITIONS
// Extends base schema (Admin, AdminSession, Programme, Participant, etc.)
// ─────────────────────────────────────────────


// ─── PERMISSIONS & ROLES ─────────────────────

enum Permission {
  // Admin management
  admin_create
  admin_update
  admin_delete
  admin_view

  // Role management
  role_create
  role_update
  role_delete
  role_view
  role_assign

  // Programme management
  programme_create
  programme_update
  programme_delete
  programme_view
  programme_assign_admin

  // Participant management
  participant_create
  participant_update
  participant_delete
  participant_view

  // Invoice & payments
  invoice_create
  invoice_update
  invoice_delete
  invoice_view
  invoice_send

  // Events & flows
  event_create
  event_update
  event_delete
  event_view
  event_trigger

  // Forms
  form_create
  form_update
  form_delete
  form_view
  form_submissions_view

  // Opportunities
  opportunity_create
  opportunity_update
  opportunity_delete
  opportunity_view

  // Comms
  comms_post
  comms_delete
  comms_view
  comms_tag

  // Tasks
  task_create
  task_update
  task_delete
  task_view
  task_assign

  // Resources
  resource_create
  resource_update
  resource_delete
  resource_view

  // Notifications
  notification_view
  notification_manage

  // Org-level
  org_settings_view
  org_settings_update
}

// System seed roles: super, standard, basic, read_only
// Admins can create custom roles beyond these
model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  isSystem    Boolean      @default(false)     // true = seeded, protected from deletion
  permissions String[]     @default([])        // cast to/from Permission enum in app layer
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  admins      Admin[]
  programmeAssignments AdminProgrammeAssignment[]
}


