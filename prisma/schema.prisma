generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

enum PaymentStatus {
  not_invoiced
  invoiced
  paid
  overdue
}

enum StepStatus {
  not_sent
  sent
  completed
}

enum EventBaseType {
  send_email
  send_invoice
}

enum EventStatus {
  pending
  processing
  completed
  failed
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
}

enum AdminRole {
  super
  standard
  basic
  read_only
}

enum OpportunityStatus {
  open
  nurturing
  converted
  archived
}

enum OpportunityEventStatus {
  pending
  scheduled
  completed
  cancelled
  failed
}

enum Permission {
  admin_create
  admin_update
  admin_delete
  admin_view
  role_create
  role_update
  role_delete
  role_view
  role_assign
  programme_create
  programme_update
  programme_delete
  programme_view
  programme_assign_admin
  participant_create
  participant_update
  participant_delete
  participant_view
  invoice_create
  invoice_update
  invoice_delete
  invoice_view
  invoice_send
  event_create
  event_update
  event_delete
  event_view
  event_trigger
  form_create
  form_update
  form_delete
  form_view
  form_submissions_view
  opportunity_create
  opportunity_update
  opportunity_delete
  opportunity_view
  comms_post
  comms_delete
  comms_view
  comms_tag
  task_create
  task_update
  task_delete
  task_view
  task_assign
  resource_create
  resource_update
  resource_delete
  resource_view
  notification_view
  notification_manage
  org_settings_view
  org_settings_update
}

enum NotificationType {
  form_submission
  form_submitted
  event_run
  event_deployed
  event_failed
  event_completed
  payment_received
  payment_overdue
  invoice_sent
  invoice_created
  participant_added
  participant_updated
  participant_enrolled
  programme_update
  task_assigned
  task_completed
  comms_tag
  admin_added
  opportunity_converted
  error
  info
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum TaskStatus {
  open
  in_progress
  blocked
  done
  cancelled
}

enum ResourceType {
  link
  document
  video
  spreadsheet
  image
  other
}

model Role {
  id                   String                     @id @default(cuid())
  name                 String                     @unique
  description          String?
  isSystem             Boolean                    @default(false)
  permissions          String[]                   @default([])
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  admins               Admin[]                    @relation("AdminRoleAssignments")
  programmeAssignments AdminProgrammeAssignment[]
}

model Participant {
  id                  String                   @id @default(cuid())
  name                String
  email               String                   @unique
  organisation        String?
  address             String?
  phone               String?
  socialLinks         String[]                 @default([])
  photoId             String?
  stripeCustomerId    String?                  @unique
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  notes               String?
  metadata            Json                     @default("{}")
  programmes          ProgrammeParticipant[]
  eventStatuses       EventParticipantStatus[]
  formSubmissions     FormSubmission[]
  participantInvoices ParticipantInvoice[]
}

model ProgrammeParticipant {
  id            String              @id @default(cuid())
  programmeId   String
  participantId String
  invoiceId     String?             @unique
  paymentStatus PaymentStatus       @default(not_invoiced)
  metadata      Json                @default("{}")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  programme     Programme           @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  participant   Participant         @relation(fields: [participantId], references: [id], onDelete: Cascade)
  invoice       ParticipantInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@unique([programmeId, participantId])
  @@index([participantId])
}

model Programme {
  id                    String                     @id @default(cuid())
  name                  String
  description           String?
  costPerParticipant    Float?
  startDate             DateTime
  metadata              Json                       @default("{}")
  eventFlow             EventFlow?
  participants          ProgrammeParticipant[]
  events                Event[]
  formTables            FormTable[]
  forms                 Form[]
  participantInvoices   ParticipantInvoice[]
  emailTemplates        EmailTemplate[]
  adminAssignments      AdminProgrammeAssignment[]
  commsChannel          ProgrammeCommsChannel?
  tasks                 Task[]
  resources             ProgrammeResource[]
}

model EventFlow {
  id          String    @id @default(cuid())
  programmeId String    @unique
  flow        Json      @default("{}")
  deployedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  programme   Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  events      Event[]
}

model Event {
  id                  String                   @id @default(cuid())
  name                String
  programmeId         String
  eventFlowId         String?
  baseType            EventBaseType
  scheduledAt         DateTime
  status              EventStatus              @default(pending)
  config              Json
  createdAt           DateTime                 @default(now())
  programme           Programme                @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  eventFlow           EventFlow?               @relation(fields: [eventFlowId], references: [id], onDelete: SetNull)
  participantStatuses EventParticipantStatus[]
  formTables          FormTable[]
  forms               Form[]
}

model EventParticipantStatus {
  id            String      @id @default(cuid())
  eventId       String
  participantId String
  status        StepStatus  @default(not_sent)
  metadata      Json        @default("{}")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  event         Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([eventId, participantId])
  @@index([participantId])
}

model Form {
  id          String           @id @default(cuid())
  programmeId String?
  eventId     String?
  slug        String           @unique
  name        String
  description String?
  status      String           @default("draft")
  sections    Json
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  programme   Programme?       @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  event       Event?           @relation(fields: [eventId], references: [id], onDelete: SetNull)
  submissions FormSubmission[]
}

model FormSubmission {
  id           String       @id @default(cuid())
  formId       String
  respondentId String?
  answers      Json
  metadata     Json         @default("{}")
  createdAt    DateTime     @default(now())
  form         Form         @relation(fields: [formId], references: [id], onDelete: Cascade)
  participant  Participant? @relation(fields: [respondentId], references: [id], onDelete: SetNull)

  @@index([formId])
  @@index([respondentId])
}

model FormTable {
  id          String    @id @default(cuid())
  programmeId String
  eventId     String
  name        String
  formSchema  Json
  entries     Json
  programme   Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model ParticipantInvoice {
  id                   String                @id @default(cuid())
  programmeId          String
  participantId        String
  amount               Float
  currency             String                @default("GBP")
  status               InvoiceStatus         @default(draft)
  dueDate              DateTime
  paidAt               DateTime?
  stripeInvoiceId      String?               @unique
  stripeInvoiceUrl     String?
  stripeInvoiceItemIds String[]              @default([])
  lineItems            Json                  @default("[]")
  metadata             Json                  @default("{}")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  participant          Participant           @relation(fields: [participantId], references: [id], onDelete: Cascade)
  programme            Programme             @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  programmeParticipant ProgrammeParticipant?

  @@unique([programmeId, participantId])
  @@index([participantId])
  @@index([programmeId])
}

model EmailTemplate {
  id          String    @id @default(cuid())
  programmeId String
  name        String
  subject     String
  body        String
  programme   Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
}

model Admin {
  id                    String                     @id @default(cuid())
  name                  String
  email                 String                     @unique
  role                  AdminRole                  @default(read_only)
  roleId                String?
  password              String
  notificationsEnabled  Boolean                    @default(true)
  photoId               String?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  sessions              AdminSession[]
  roleModel             Role?                      @relation("AdminRoleAssignments", fields: [roleId], references: [id], onDelete: SetNull)
  programmeAssignments  AdminProgrammeAssignment[]
  orgCommsThreads       OrgCommsThread[]           @relation("OrgCommsAuthor")
  orgCommsReplies       OrgCommsReply[]            @relation("OrgCommsReplyAuthor")
  orgCommsTags          OrgCommsTag[]
  programmeCommsThreads ProgrammeCommsThread[]     @relation("ProgrammeCommsAuthor")
  programmeCommsReplies ProgrammeCommsReply[]      @relation("ProgrammeCommsReplyAuthor")
  programmeCommsTags    ProgrammeCommsTag[]
  notifications         Notification[]
  assignedTasks         Task[]                     @relation("TaskAssignee")
  createdTasks          Task[]                     @relation("TaskCreator")
  assignedTaskItems     TaskItem[]                 @relation("TaskItemAssignee")
  programmeResources    ProgrammeResource[]        @relation("ProgrammeResourceAddedBy")
}

model AdminSession {
  id         String    @id @default(cuid())
  adminId    String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime  @default(now())
  admin      Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([expiresAt])
}

model Opportunity {
  id              String             @id @default(cuid())
  name            String
  email           String             @unique
  organisation    String?
  importanceScore Int                @default(0)
  status          OpportunityStatus  @default(open)
  notes           String?
  metadata        Json               @default("{}")
  events          OpportunityEvent[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model OpportunityPipeline {
  id        String                    @id @default(cuid())
  name      String
  flow      Json                      @default("{}")
  steps     OpportunityPipelineStep[]
  events    OpportunityEvent[]
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt
}

model OpportunityPipelineStep {
  id         String              @id @default(cuid())
  pipelineId String
  name       String
  type       String              @default("send_email")
  delayDays  Int                 @default(0)
  config     Json                @default("{}")
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  pipeline   OpportunityPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  events     OpportunityEvent[]

  @@index([pipelineId])
}

model OpportunityEvent {
  id             String                   @id @default(cuid())
  opportunityId  String
  pipelineId     String?
  pipelineStepId String?
  name           String
  type           String                   @default("send_email")
  scheduledAt    DateTime
  status         OpportunityEventStatus   @default(pending)
  cronJobId      String                   @unique
  config         Json                     @default("{}")
  error          String?
  completedAt    DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  opportunity    Opportunity              @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  pipeline       OpportunityPipeline?     @relation(fields: [pipelineId], references: [id], onDelete: SetNull)
  pipelineStep   OpportunityPipelineStep? @relation(fields: [pipelineStepId], references: [id], onDelete: SetNull)

  @@index([opportunityId])
  @@index([pipelineId])
  @@index([pipelineStepId])
}

model AdminProgrammeAssignment {
  id          String    @id @default(cuid())
  adminId     String
  programmeId String
  roleId      String?
  assignedAt  DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  admin       Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  programme   Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  role        Role?     @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([adminId, programmeId])
  @@index([adminId])
  @@index([programmeId])
  @@index([roleId])
}

model OrgCommsThread {
  id        String          @id @default(cuid())
  authorId  String
  title     String
  body      String
  isPinned  Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  author    Admin           @relation("OrgCommsAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  tags      OrgCommsTag[]
  replies   OrgCommsReply[]

  @@index([authorId])
  @@index([createdAt])
}

model OrgCommsReply {
  id        String          @id @default(cuid())
  threadId  String
  authorId  String
  body      String
  parentId  String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  thread    OrgCommsThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author    Admin           @relation("OrgCommsReplyAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parent    OrgCommsReply?  @relation("OrgCommsReplies", fields: [parentId], references: [id], onDelete: SetNull)
  children  OrgCommsReply[] @relation("OrgCommsReplies")

  @@index([threadId])
  @@index([authorId])
  @@index([parentId])
}

model OrgCommsTag {
  id       String         @id @default(cuid())
  threadId String
  adminId  String
  thread   OrgCommsThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  admin    Admin          @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([threadId, adminId])
  @@index([adminId])
}

model ProgrammeCommsChannel {
  id          String                 @id @default(cuid())
  programmeId String                 @unique
  createdAt   DateTime               @default(now())
  programme   Programme              @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  threads     ProgrammeCommsThread[]
}

model ProgrammeCommsThread {
  id        String                @id @default(cuid())
  channelId String
  authorId  String
  title     String
  body      String
  isPinned  Boolean               @default(false)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  channel   ProgrammeCommsChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author    Admin                 @relation("ProgrammeCommsAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  tags      ProgrammeCommsTag[]
  replies   ProgrammeCommsReply[]

  @@index([channelId])
  @@index([authorId])
  @@index([createdAt])
}

model ProgrammeCommsReply {
  id        String                @id @default(cuid())
  threadId  String
  authorId  String
  body      String
  parentId  String?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  thread    ProgrammeCommsThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author    Admin                 @relation("ProgrammeCommsReplyAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parent    ProgrammeCommsReply?  @relation("ProgrammeCommsReplies", fields: [parentId], references: [id], onDelete: SetNull)
  children  ProgrammeCommsReply[] @relation("ProgrammeCommsReplies")

  @@index([threadId])
  @@index([authorId])
  @@index([parentId])
}

model ProgrammeCommsTag {
  id       String               @id @default(cuid())
  threadId String
  adminId  String
  thread   ProgrammeCommsThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  admin    Admin                @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([threadId, adminId])
  @@index([adminId])
}

model Notification {
  id        String           @id @default(cuid())
  adminId   String
  type      NotificationType
  title     String
  body      String?
  read      Boolean          @default(false)
  payload   Json             @default("{}")
  createdAt DateTime         @default(now())
  admin     Admin            @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([read])
  @@index([createdAt])
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  programmeId String?
  assigneeId  String?
  createdById String
  priority    TaskPriority @default(medium)
  status      TaskStatus   @default(open)
  dueDate     DateTime?
  metadata    Json         @default("{}")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  assignee    Admin?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy   Admin        @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  programme   Programme?   @relation(fields: [programmeId], references: [id], onDelete: SetNull)
  items       TaskItem[]

  @@index([assigneeId])
  @@index([createdById])
  @@index([programmeId])
  @@index([status])
}

model TaskItem {
  id         String   @id @default(cuid())
  taskId     String
  label      String
  completed  Boolean  @default(false)
  assigneeId String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignee   Admin?   @relation("TaskItemAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([assigneeId])
}

model ProgrammeResource {
  id          String       @id @default(cuid())
  programmeId String
  label       String
  url         String
  type        ResourceType @default(link)
  description String?
  addedById   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  programme   Programme    @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  addedBy     Admin?       @relation("ProgrammeResourceAddedBy", fields: [addedById], references: [id], onDelete: SetNull)

  @@index([programmeId])
  @@index([addedById])
}
